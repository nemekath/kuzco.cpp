#!/usr/bin/env bash
# pre-push — Block tag pushes that have no CHANGELOG.md entry.
#
# Git calls pre-push with the remote name and URL as arguments,
# and feeds pushed refs on stdin (one line per ref):
#   <local ref> <local sha> <remote ref> <remote sha>

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
CHANGELOG="${REPO_ROOT}/CHANGELOG.md"

ERRORS=0

while read -r local_ref local_sha remote_ref remote_sha; do
    # Only check version tags (refs/tags/v*)
    case "$remote_ref" in
        refs/tags/v*)
            tag="${remote_ref#refs/tags/}"
            if ! grep -qE "^## ${tag}( |$)" "$CHANGELOG" 2>/dev/null; then
                echo "BLOCKED: Pushing tag '${tag}' but no '## ${tag}' section in CHANGELOG.md"
                echo "  Add a changelog entry before pushing this tag."
                ERRORS=$((ERRORS + 1))
            fi
            ;;
    esac
done

if [[ $ERRORS -gt 0 ]]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Push blocked: ${ERRORS} tag(s) missing CHANGELOG.md entry."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
fi
