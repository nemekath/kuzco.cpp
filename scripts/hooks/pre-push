#!/usr/bin/env bash
# pre-push — Safety guards for pushing to remote.
#
# Blocks:
#   - Any push to the upstream remote
#   - Any push to master (upstream tracking branch)
#   - Non-fast-forward (force) pushes to tmac
#   - Tag pushes without CHANGELOG.md entry
# Warns:
#   - Direct pushes to tmac (suggests feature branch)
#
# Git calls pre-push with the remote name and URL as arguments,
# and feeds pushed refs on stdin (one line per ref):
#   <local ref> <local sha> <remote ref> <remote sha>

set -euo pipefail

REMOTE="$1"
REMOTE_URL="${2:-}"

REPO_ROOT="$(git rev-parse --show-toplevel)"
CHANGELOG="${REPO_ROOT}/CHANGELOG.md"

ERRORS=0

warn() { printf '\033[1;33m[pre-push]\033[0m %s\n' "$*"; }
block() { printf '\033[1;31m[pre-push]\033[0m %s\n' "$*"; }

# ── Guard 1: Block all pushes to upstream remote ─────────────────────
if [[ "$REMOTE" == "upstream" ]]; then
    block "BLOCKED: Pushing to upstream remote is not allowed."
    block "  The upstream remote (ggml-org/llama.cpp) is read-only for merging."
    exit 1
fi

# ── Process each ref being pushed ────────────────────────────────────
while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip delete operations (local_sha is all zeros)
    if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
        continue
    fi

    case "$remote_ref" in
        # ── Guard 2: Block pushes to master ──────────────────────
        refs/heads/master)
            block "BLOCKED: Pushing to 'master' is not allowed."
            block "  The master branch tracks upstream and should never be pushed to."
            block "  Push to 'tmac' or a feature branch instead."
            ERRORS=$((ERRORS + 1))
            ;;

        # ── Guard 3: Force-push protection + warn for tmac ──────
        refs/heads/tmac)
            if [[ "$remote_sha" != "0000000000000000000000000000000000000000" ]] \
               && ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
                block "BLOCKED: Non-fast-forward push to 'tmac' is not allowed."
                block "  This would rewrite history. Use a feature branch instead."
                ERRORS=$((ERRORS + 1))
            else
                warn "Pushing directly to 'tmac' (main branch)."
                warn "  Consider using a feature branch + PR for larger changes."
            fi
            ;;

        # ── Guard 4: Tag changelog validation ────────────────────
        refs/tags/v*)
            tag="${remote_ref#refs/tags/}"
            escaped_tag=$(printf '%s' "$tag" | sed 's/[].[+*?^${}()|\\]/\\&/g')
            if ! grep -qE "^## ${escaped_tag}( |$)" "$CHANGELOG" 2>/dev/null; then
                block "BLOCKED: Pushing tag '${tag}' but no '## ${tag}' section in CHANGELOG.md"
                block "  Add a changelog entry before pushing this tag."
                ERRORS=$((ERRORS + 1))
            fi
            ;;
    esac
done

if [[ $ERRORS -gt 0 ]]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Push blocked: ${ERRORS} violation(s) found."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
fi
